//grade calculation

class practice{
    public static void main (String []args){
        
        int mark = 90;
        
        if(mark>=90){
            System.out.println("A grade");
        }
        else if(mark>=75){
            System.out.println("B grade");
        }
        else if(mark>=50){
            System.out.println("C grade");
        }
        else{
            System.out.println("D grade");
        }
        
    }
    
}
